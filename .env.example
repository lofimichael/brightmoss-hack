# CHECKPOINT operator configuration
#
# Consumers never fill this file out. The local Mac experience launches with no
# provider keys. This file exists only for the hackathon operator build and OSS
# contributors exercising sponsor integrations.

# Bright Data public-web enrichment. A token alone uses Bright Data's remote
# MCP search path; zones are optional direct-API overrides.
BRIGHT_DATA_API_KEY=
# The common BRIGHTDATA_API_KEY spelling is also accepted; the name above wins
# when both are present.
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_UNLOCKER_ZONE=

# Moss local session retrieval. When both values are present, CHECKPOINT enables
# Moss automatically, creates a fresh local session, and never pushes it.
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_MODEL_ID=moss-minilm
MOSS_DISABLE_TELEMETRY=1

# LiveKit client configuration. The sandbox ID is development-only and is not a
# secret; a production app receives an ephemeral participant token from a
# service instead. The agent name has a built-in default.
LIVEKIT_SANDBOX_ID=
LIVEKIT_AGENT_NAME=checkpoint

# LiveKit voice-worker credentials remain operator-side and never enter the Mac
# app bundle. They are needed only to run the cloud voice worker.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional cloud planner. The LiveKit worker below uses LiveKit Inference and
# does not require a separate OpenAI credential. Ambient capture, extraction,
# and native same-Mac voice never use this key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional LiveKit Inference overrides. Blank values use the worker's defaults.
# These are model identifiers, not additional credentials.
LIVEKIT_INFERENCE_STT_MODEL=
LIVEKIT_INFERENCE_LLM_MODEL=
LIVEKIT_INFERENCE_TTS_MODEL=
LIVEKIT_INFERENCE_TTS_VOICE=
LIVEKIT_INFERENCE_LANGUAGE=

# Advanced local-helper overrides. Leave blank for the consumer-shaped demo.
CHECKPOINT_PORT=8765
CHECKPOINT_DATA_DIR=
